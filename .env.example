# ── Supabase ──────────────────────────────────────────────────────────────────
# Required for database access and authentication.
# Find these in Supabase Dashboard → Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── ISO New England ────────────────────────────────────────────────────────────
# Required for live grid load data (/api/grid).
# Register at iso-ne.com/isoexpress/web/login.
# Without these the app falls back to mock grid data.

ISONE_API_USER=your-isone-username
ISONE_API_PASSWORD=your-isone-password

# ── U.S. Energy Information Administration ────────────────────────────────────
# Required for live regional load growth data (/api/analytics).
# Register at eia.gov/opendata.
# Without this the app falls back to mock analytics data.

EIA_API_KEY=your-eia-api-key

# ── U.S. Census Bureau ────────────────────────────────────────────────────────
# Optional — used for county-level population data.
# Register at api.census.gov/data/key_signup.html.
# Without this the app falls back to mock demographic data.

CENSUS_API_KEY=your-census-api-key

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Required for AI-powered copilot insights in the Planning Platform.
# Register at console.anthropic.com and create an API key.
# Without this key the AI section is hidden (graceful fallback — app still works).

ANTHROPIC_API_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Required for subscription billing. Configure in the Stripe Dashboard.
# Without these keys billing is disabled (app still works for non-billing features).

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRODUCT_STARTER=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRODUCT_PROFESSIONAL=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=
STRIPE_PRODUCT_ENTERPRISE=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_ANNUAL=

# ── Development / Mock Data ───────────────────────────────────────────────────
# Set to "true" to enable dev seeding (serve mock substation data when DB is empty).
# Never set in production — empty DB returns an empty portfolio instead of mock data.

NEXT_PUBLIC_USE_MOCK_DATA=true
